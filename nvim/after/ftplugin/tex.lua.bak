-- after/ftplugin/tex.lua
-- Custom LaTeX highlighting for VimTeX syntax groups on TokyoNight (night).
--
-- INSTALLATION
--   Place this file at:  ~/.config/nvim/after/ftplugin/tex.lua
--
-- PREREQUISITES
--   1. Treesitter highlighting is DISABLED for tex (see the accompanying
--      treesitter override plugin spec, or add `tex` to the `disable` list
--      in your treesitter config).
--   2. VimTeX is the primary syntax provider (vim.g.vimtex_syntax_enabled
--      should be 1, which is the default).
--   3. TokyoNight "night" is your active colorscheme.
--
-- These highlights are set buffer-locally via nvim_set_hl with ns_id = 0,
-- which means they apply globally but are loaded only when a TeX buffer is
-- opened.  If you prefer namespace isolation, create a dedicated namespace.

local hl = function(group, opts)
  vim.api.nvim_set_hl(0, group, opts)
end

------------------------------------------------------------------------
-- TokyoNight (night) palette reference
------------------------------------------------------------------------
local C = {
  fg        = "#c0caf5",
  fg_dim    = "#a9b1d6",
  fg_muted  = "#737aa2",
  bg        = "#1a1b26",
  blue      = "#7aa2f7",
  cyan      = "#7dcfff",
  teal      = "#1abc9c",
  green     = "#9ece6a",
  magenta   = "#bb9af7",
  orange    = "#ff9e64",
  red       = "#f7768e",
  yellow    = "#e0af68",
  comment   = "#565f89",
  dark5     = "#737aa2",
  -- Derived / adjusted tones
  math_fg   = "#c3c1f5",  -- slight violet tint for math body
  arg_fg    = "#9aa5ce",   -- muted foreground for arguments
  delim     = "#545c7e",   -- subtle brace/bracket colour
  env_bg    = "#1e1f2e",   -- very faint background tint (optional)
}


------------------------------------------------------------------------
-- 1. BASE COMMANDS  —  the fallback for any \command not caught below
------------------------------------------------------------------------
hl("texCmd",              { fg = C.blue })
hl("texCmdType",          { fg = C.blue })


------------------------------------------------------------------------
-- 2. SECTIONING  —  the structural skeleton of the document
------------------------------------------------------------------------
hl("texCmdPart",          { fg = C.orange, bold = true })
-- The title argument of \section{Title} gets its own group:
hl("texPartArgTitle",     { fg = C.orange, bold = true })


------------------------------------------------------------------------
-- 3. ENVIRONMENT DELIMITERS  —  \begin / \end
------------------------------------------------------------------------
hl("texCmdEnv",           { fg = C.teal })
-- The environment name inside \begin{theorem}:
hl("texEnvArgName",       { fg = C.cyan, bold = true })


------------------------------------------------------------------------
-- 4. MATH  —  delimiters, body, and commands within math
------------------------------------------------------------------------
-- Math delimiters: $, $$, \(, \), \[, \]
hl("texMathDelim",        { fg = C.magenta })
hl("texMathDelimZone",    { fg = C.magenta })
-- Paired delimiters produced by \left( ... \right)
hl("texMathCmdParen",     { fg = C.magenta })

-- Math body: give it a distinct tint so you can see mode boundaries
hl("texMathZone",         { fg = C.math_fg, italic = true })
hl("texMathZoneLi",       { fg = C.math_fg, italic = true })  -- inline $...$
hl("texMathZoneLd",       { fg = C.math_fg, italic = true })  -- display \[...\]
hl("texMathZoneEnv",      { fg = C.math_fg, italic = true })  -- equation, align, etc.
hl("texMathZoneTi",       { fg = C.math_fg, italic = true })  -- \(...\)
hl("texMathZoneTd",       { fg = C.math_fg, italic = true })  -- \[...\]

-- Commands used inside math mode (\frac, \sum, \subseteq, your custom ops)
hl("texMathCmd",          { fg = C.blue })
-- Superscript/subscript markers
hl("texMathSuperSub",     { fg = C.dark5 })
-- Math operators (\cap, \cup, \in, etc.)
hl("texMathOper",         { fg = C.fg_dim })


------------------------------------------------------------------------
-- 5. CITATIONS AND REFERENCES
------------------------------------------------------------------------
-- \cite, \ref, \eqref, \pageref, \autoref, \label, \footref
hl("texCmdRef",           { fg = C.green })
-- The key/label argument inside \cite{chellas1980} or \ref{lem:truth-lemma}
hl("texRefArg",           { fg = C.green, italic = true })


------------------------------------------------------------------------
-- 6. PREAMBLE / PACKAGE COMMANDS
------------------------------------------------------------------------
hl("texCmdPackage",       { fg = C.red })
hl("texCmdClass",         { fg = C.red })
-- Package/class name arguments
hl("texFileArg",          { fg = C.red, italic = true })
-- Options in \usepackage[opts]{pkg}
hl("texFileOpt",          { fg = C.dark5 })


------------------------------------------------------------------------
-- 7. MACRO DEFINITIONS  —  \newcommand, \renewcommand, \def, etc.
------------------------------------------------------------------------
hl("texCmdDef",           { fg = C.yellow, bold = true })
-- The name of the command being defined
hl("texDefArgName",       { fg = C.yellow })


------------------------------------------------------------------------
-- 8. INPUT / INCLUDE
------------------------------------------------------------------------
hl("texCmdInput",         { fg = C.red })


------------------------------------------------------------------------
-- 9. FOOTNOTES
------------------------------------------------------------------------
hl("texCmdFootnote",      { fg = C.dark5, italic = true })


------------------------------------------------------------------------
-- 10. TITLE / AUTHOR (mostly in preamble)
------------------------------------------------------------------------
hl("texCmdTitle",         { fg = C.orange, bold = true })
hl("texCmdAuthor",        { fg = C.orange })


------------------------------------------------------------------------
-- 11. ARGUMENTS AND DELIMITERS  —  keep these unobtrusive
------------------------------------------------------------------------
-- Generic argument text (between { and })
hl("texArg",              { fg = C.arg_fg })
-- Optional arguments (between [ and ])
hl("texOpt",              { fg = C.dark5 })
-- The braces / brackets themselves
hl("texDelim",            { fg = C.delim })
-- Group delimiters in special positions
hl("texGroupDelim",       { fg = C.delim })


------------------------------------------------------------------------
-- 12. COMMENTS  —  leave mostly as TokyoNight sets them, but ensure
--     they are clearly recessive
------------------------------------------------------------------------
hl("texComment",          { fg = C.comment, italic = true })


------------------------------------------------------------------------
-- 13. SPECIAL TEXT COMMANDS
------------------------------------------------------------------------
-- \textbf, \textit, \emph, \textsc, etc. — style the command itself
hl("texCmdStyle",         { fg = C.blue, italic = true })
-- The argument of \emph{...} — apply italic so you see the effect in-editor
hl("texStyleItal",        { fg = C.fg, italic = true })
hl("texStyleBold",        { fg = C.fg, bold = true })


------------------------------------------------------------------------
-- 14. MISCELLANEOUS
------------------------------------------------------------------------
-- \item in list environments
hl("texCmdItem",          { fg = C.teal })
-- Verbatim / lstlisting
hl("texCmdVerb",          { fg = C.green })
hl("texVerbZone",         { fg = C.fg_dim })
-- Spacing commands: \\, \hfill, \medskip, etc.
hl("texCmdSpacing",       { fg = C.delim })
-- \noindent, \clearpage, etc.
hl("texCmdLayout",        { fg = C.delim })


------------------------------------------------------------------------
-- 15. LINKS (if hyperref is detected by VimTeX)
------------------------------------------------------------------------
hl("texCmdHyperref",      { fg = C.cyan, underline = true })
