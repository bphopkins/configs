{
  "layer": "top",
  "position": "top",

  "modules-left":   ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right":  ["tray", "pulseaudio", "backlight", "battery"],

  "clock": { "format": "{:%Y-%m-%d %T}" },                 // 24-hr, your exact format
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}%"
  },
  "pulseaudio": { "format": "{volume}%", "tooltip": false },
  "battery": { "format": "{capacity}% {icon}" },
  "tray": { "icon-size": 16, "spacing": 8 }
}
