    \aliascntresetthe{example}
    \crefname{example}{example}{examples}
    \Crefname{example}{Example}{Examples}

  \theoremstyle{noindentremark}
    \newaliascnt{remark}{theorem}
    \newtheorem{remark}[remark]{Remark}
    \aliascntresetthe{remark}
    \crefname{remark}{remark}{remarks}
    \Crefname{remark}{Remark}{Remarks}
    \AtEndEnvironment{remark}{\remarkqed}

    \newaliascnt{note}{theorem}
    \newtheorem{note}[note]{Note}
    \aliascntresetthe{note}
    \crefname{note}{note}{notes}
    \Crefname{note}{Note}{Notes}
    \AtEndEnvironment{note}{\remarkqed}

    \newaliascnt{convention}{theorem}
    \newtheorem{convention}[convention]{Convention}
    \aliascntresetthe{convention}
    \crefname{convention}{convention}{conventions}
    \Crefname{convention}{Convention}{Conventions}
    \AtEndEnvironment{convention}{\remarkqed}

    \newaliascnt{observation}{theorem}
    \newtheorem{observation}[observation]{Observation}
    \aliascntresetthe{observation}
    \crefname{observation}{observation}{observations}
    \Crefname{observation}{Observation}{Observations}
    \AtEndEnvironment{observation}{\remarkqed}

    \newaliascnt{digression}{theorem}
