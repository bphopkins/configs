    \renewenvironment{proof}[1][\proofname]{\par
      \pushQED{\qed}%
      \normalfont
      \topsep6\p@\@plus6\p@\relax
      \trivlist
      \item[\hskip\labelsep
        \itshape
        #1\@addpunct{.}]\ignorespaces
      }{%
        \popQED\endtrivlist\@endpefalse
      }
    \newenvironment{proofsketch}[1][Proof sketch]{\par
    \pushQED{\sketchqed}%
    \normalfont
    \topsep6\p@\@plus6\p@\relax
    \trivlist
    \item[\hskip\labelsep
      \itshape
      #1\@addpunct{.}]\ignorespaces\leavevmode
    }{%
      \popQED\endtrivlist\@endpefalse
    }
  \makeatother

  \newenvironment{block}{\begin{list}{}{\setlength{\leftmargin}{2em} % Set left margin
    \setlength{\rightmargin}{0em}} % Set right margin to 0
